{
    "name": "gamestore-fe-erp",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc && vite build",
        "start": "node --env-file=.env node_modules/serve/build/main.js -s dist",
        "preview": "vite preview",
        "test": "vitest",
        "test:e2e": "playwright test",
        "lint": "eslint . --fix",
        "format": "prettier --write \"**/*.{js,ts,vue,css,json}\""
    },
    "dependencies": {
        "pinia": "^2.1.7",
        "serve": "^14.2.6",
        "vue": "^3.4.29",
        "vue-router": "^4.3.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@vitejs/plugin-vue": "^5.0.5",
        "@vitejs/plugin-vue-jsx": "^5.1.5",
        "@vue/test-utils": "^2.4.6",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.0",
        "globals": "^17.5.0",
        "happy-dom": "^20.9.0",
        "prettier": "^3.8.3",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.59.0",
        "vite": "^5.3.1",
        "vitest": "^1.6.0",
        "vue-tsc": "^2.0.21"
    }
}
